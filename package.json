{
  "name": "@francocdev/ai-chat-widget",
  "version": "0.5.5",
  "description": "Drop-in AI chat widget for React apps. Configurable, themeable, with Markdown support.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "chat",
    "ai",
    "widget",
    "react",
    "ai-sdk",
    "vercel-ai",
    "chatbot"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Franco Carrara <me@francoc.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/FrancocDev/ai-chat-widget"
  },
  "peerDependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "@ai-sdk/react": "^3.0.0",
    "ai": "^6.0.0",
    "lucide-react": "^0.484.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "focus-trap-react": "^12.0.2",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6"
  }
}
